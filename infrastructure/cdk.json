{
  "app": "npx ts-node bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "yarn.lock",
      "node_modules",
      "test",
      "dist"
    ]
  },
  "context": {
    "projectName": "sap-demo",
    "environments": {
      "dev": {
        "account": "${CDK_DEFAULT_ACCOUNT}",
        "region": "us-east-1"
      }
    }
  }
}
