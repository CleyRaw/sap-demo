# ─── Copia este archivo como .env.dev y completa los valores ─────────────────
# .env.dev está en .gitignore — nunca lo commitees

# AWS
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1
AWS_PROFILE=tu-perfil-aqui

# CDK Context (alternativa a cdk.json para sobreescribir por ambiente)
CDK_ENV=dev
CDK_PROJECT_NAME=sap-demo
